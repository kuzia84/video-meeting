#!/usr/bin/env sh
# Reject commit messages corrupted by a leaked shell here-string delimiter.
#
# On Windows the shell is PowerShell, whose here-strings are @'...'@ / @"..."@.
# When one leaks its markers into the message (the closing '@ not at column 0,
# or the model emitting a bare @ line) the subject becomes a lone "@" — which is
# what GitHub then shows for the commit. Catch it here so a malformed message
# can never land, regardless of which shell or skill produced the commit.

msg_file="$1"

# Every non-empty line must not be a bare here-string delimiter.
line_no=0
while IFS= read -r line || [ -n "$line" ]; do
  line_no=$((line_no + 1))
  case "$line" in
  '@' | "@'" | "'@" | '@"' | '"@')
    echo "commit-msg: line $line_no is a stray here-string delimiter: '$line'" >&2
    echo "" >&2
    echo "A PowerShell here-string (@'...'@) leaked its markers into the commit message." >&2
    echo "Don't build the message with shell here-strings/heredocs. Instead write it to a" >&2
    echo "file and commit with:  git commit -F <path-to-message-file>" >&2
    exit 1
    ;;
  esac
done <"$msg_file"

exit 0
