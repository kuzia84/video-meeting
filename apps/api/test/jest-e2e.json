{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "maxWorkers": 1,
  "testRegex": ".e2e-spec.ts$",
  "globalSetup": "<rootDir>/global-setup.ts",
  "setupFiles": ["<rootDir>/setup-e2e.ts"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@video-meetings/shared$": "<rootDir>/../../../packages/shared/src/index.ts"
  }
}
