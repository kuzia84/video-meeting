# Use your own DB password here — must match POSTGRES_PASSWORD in the root .env.
DATABASE_URL=postgresql://postgres:change-me@localhost:5432/video_meetings
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1h
# Comma-separated list of allowed CORS origins (defaults to http://localhost:3000)
CORS_ORIGINS=http://localhost:3000
# Where uploaded meeting files are stored. Relative paths resolve against the API's
# working directory; defaults to ./uploads. In Docker this must be a mounted volume,
# otherwise uploads die with the container.
UPLOAD_DIR=./uploads
