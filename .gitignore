# Coverage
coverage

# Uploaded meeting files (dev storage and the isolated e2e run directory)
apps/api/uploads
apps/api/test/.uploads-e2e

# Playwright MCP snapshot/screenshot artifacts
.playwright-mcp

# Playwright test run output (traces, reports)
test-results
playwright-report

# Env & secrets — never commit real values. Only *.example templates
# (with placeholder values) are allowed in git; every real .env is ignored.
.env
.env.*
!.env.example
!.env.*.example

